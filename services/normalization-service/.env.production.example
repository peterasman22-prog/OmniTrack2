# ─── OmniTrack Normalization Service - Production Environment Variables ──────
# Set these in Railway's service variables dashboard.

NODE_ENV=production
SERVICE_NAME=omnitrack-normalization-service

# NATS - Use Railway internal networking or external NATS service
NATS_URL=nats://nats.railway.internal:4222
NATS_TOPIC_RAW=telemetry.raw
NATS_TOPIC_NORMALIZED=telemetry.normalized

# Logging
LOG_LEVEL=info
