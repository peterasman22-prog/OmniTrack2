# ─── OmniTrack API Gateway - Production Environment Variables ────────────────
# Set these in Railway's service variables dashboard.

NODE_ENV=production
PORT=4000
SERVICE_NAME=omnitrack-api-gateway

# Database - Railway provides this automatically when you add PostgreSQL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=${{Postgres.DATABASE_URL}}

# NATS - Use Railway internal networking or external NATS service
NATS_URL=nats://nats.railway.internal:4222
NATS_TOPIC_RAW=telemetry.raw
NATS_TOPIC_NORMALIZED=telemetry.normalized

# Authentication
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-secure-random-string

# CORS - Set to your frontend's Railway domain
CORS_ORIGIN=https://your-frontend.railway.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
