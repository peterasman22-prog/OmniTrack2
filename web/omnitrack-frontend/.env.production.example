# ─── OmniTrack Frontend - Production Environment Variables ───────────────────
# These are injected at BUILD TIME via Docker build args or Railway variables.
# In Railway, set these as service variables for the frontend service.

# API Gateway URL (use Railway's internal service URL or public domain)
VITE_API_BASE_URL=https://your-api-gateway.railway.app/api

# WebSocket URL (same as API Gateway for Socket.io)
VITE_WS_URL=https://your-api-gateway.railway.app
